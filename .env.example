# ============================================
# ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# ---- Azure OpenAI Configuration ----
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Name of your deployments in Azure OpenAI Studio
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4.1

# Azure OpenAI Embedding Model
AZURE_OPENAI_EMBED_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_EMBED_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small

# ---- Azure Cosmos DB (NoSQL API) Configuration ----
# Get these from Azure Portal > Your Cosmos DB Account > Keys
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_KEY=your_cosmos_primary_key_here
COSMOS_DATABASE_NAME=rag_database
COSMOS_CONTAINER_NAME=embeddings

# ---- Performance Settings ----
TOP_K=20
LLM_MAX_TOKENS=4000
MIN_SIMILARITY=0.70

# ---- Azure Cosmos DB for MongoDB (Alternative) ----
# Only needed if using MongoDB API instead of NoSQL API
MONGO_URI="mongodb://your-account:your-key@your-account.mongo.cosmos.azure.com:10255/?ssl=true&replicaSet=globaldb&retrywrites=false&maxIdleTimeMS=120000"
MONGO_DATABASE_NAME="rag_db"
MONGO_COLLECTION_NAME="document_vectors"
MONGO_INDEX_NAME="vector_index"

# ---- Application Settings ----
TOP_K=20
HYBRID_ALPHA=0.5
CHUNK_SIZE=1500
CHUNK_OVERLAP=250
MAX_WORKERS=8
BATCH_SIZE=50

# ---- LLM Settings ----
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4000

# ---- Cache Settings ----
EMBEDDING_CACHE_SIZE=1000
EMBEDDING_CACHE_TTL=3600

# ---- Logging ----
AZURE_LOG_LEVEL=WARNING

